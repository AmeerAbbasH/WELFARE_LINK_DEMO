@model WELFARE_Application_MVCF.Models.Resource

@{
    ViewData["Title"] = "Edit Resource";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4><i class="bi bi-pencil"></i> Edit Resource</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        
                        <input type="hidden" asp-for="ResourceID" />

                        <div class="mb-3">
                            <label asp-for="ProgramID" class="form-label">Programme</label>
                            <select asp-for="ProgramID" class="form-select" asp-items="ViewBag.Programs" disabled>
                            </select>
                            <input type="hidden" asp-for="ProgramID" />
                            <small class="form-text text-muted">Programme cannot be changed after creation</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Type" class="form-label">Resource Type</label>
                            <select asp-for="Type" class="form-select" asp-items="ViewBag.ResourceTypes">
                            </select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Quantity" class="form-label">Quantity / Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">₹</span>
                                <input asp-for="Quantity" type="number" step="0.01" class="form-control" />
                            </div>
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" class="form-select" asp-items="ViewBag.ResourceStatuses">
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                            <small class="form-text text-muted">
                                <strong>Available:</strong> Ready to use | 
                                <strong>Reserved:</strong> Allocated but not disbursed | 
                                <strong>Depleted:</strong> Fully consumed
                            </small>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="ManageResources" asp-route-programId="@Model.ProgramID" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-circle"></i> Update Resource
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
