@model WelfareLinkPRJ.Models.Disbursement

@{
    ViewData["Title"] = "Create Disbursement";
}

<div class="page-header">
    <h1><i class="bi bi-plus-circle-fill"></i> Record New Disbursement</h1>
    <a asp-action="Index" class="btn-modern btn-secondary-modern">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

<div class="content-card">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Benefit Info Card (shown when a benefit is selected) -->
            <div id="benefitInfoCard" class="alert alert-info mb-4" style="display: none;">
                <h5><i class="bi bi-info-circle"></i> Benefit Information</h5>
                <div class="row">
                    <div class="col-md-3">
                        <strong>Type:</strong>
                        <span id="benefitType">-</span>
                    </div>
                    <div class="col-md-3">
                        <strong>Total Amount:</strong>
                        <span id="benefitAmount">-</span>
                    </div>
                    <div class="col-md-3">
                        <strong>Already Disbursed:</strong>
                        <span id="totalDisbursed">-</span>
                    </div>
                    <div class="col-md-3">
                        <strong>Remaining Balance:</strong>
                        <span id="remainingBalance" class="fw-bold text-success">-</span>
                    </div>
                </div>
            </div>

            <!-- Amount Validation Alert -->
            <div id="amountValidationAlert" class="alert alert-danger mb-4" style="display: none;">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span id="amountValidationMessage"></span>
            </div>

            <form asp-action="Create" class="needs-validation" novalidate id="disbursementForm">
                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                <div class="row g-4">
                    <div class="col-md-12">
                        <div class="form-floating-modern">
                            <label asp-for="BenefitID" class="form-label-modern">
                                <i class="bi bi-gift"></i> Select Benefit
                            </label>
                            <select asp-for="BenefitID" class="form-select" asp-items="ViewBag.BenefitID" id="benefitSelect">
                                <option value="">-- Choose a Benefit --</option>
                            </select>
                            <span asp-validation-for="BenefitID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-floating-modern">
                            <label asp-for="Amount" class="form-label-modern">
                                <i class="bi bi-currency-rupee"></i> Disbursement Amount
                            </label>
                            <input asp-for="Amount" class="form-control" placeholder="Enter Amount" id="amountInput" min="0.01" step="0.01" />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                            <small id="amountHelp" class="text-muted">Enter amount to disburse (must be ≤ remaining balance)</small>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-floating-modern">
                            <label asp-for="CitizenID" class="form-label-modern">
                                <i class="bi bi-person-circle"></i> Citizen ID
                            </label>
                            <input asp-for="CitizenID" class="form-control" placeholder="Enter Citizen ID" min="1" />
                            <span asp-validation-for="CitizenID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-floating-modern">
                            <label asp-for="OfficerID" class="form-label-modern">
                                <i class="bi bi-person-badge"></i> Officer ID
                            </label>
                            <input asp-for="OfficerID" class="form-control" placeholder="Enter Officer ID" min="1" />
                            <span asp-validation-for="OfficerID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating-modern">
                            <label asp-for="Date" class="form-label-modern">
                                <i class="bi bi-calendar-event"></i> Disbursement Date
                            </label>
                            <input asp-for="Date" type="date" class="form-control" />
                            <span asp-validation-for="Date" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating-modern">
                            <label asp-for="Status" class="form-label-modern">
                                <i class="bi bi-flag"></i> Status
                            </label>
                            <select asp-for="Status" class="form-select" id="statusSelect">
                                <option value="">Select Status</option>
                                <option value="Completed">✅ Completed</option>
                                <option value="Pending">⏳ Pending</option>
                                <option value="Failed">❌ Failed</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex gap-3 justify-content-end">
                    <a asp-action="Index" class="btn-modern btn-secondary-modern">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                    <button type="submit" class="btn-modern btn-success-modern" id="submitBtn">
                        <i class="bi bi-check-circle"></i> Record Disbursement
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        let currentRemainingBalance = 0;

        document.getElementById('benefitSelect').addEventListener('change', function() {
            const benefitId = this.value;
            if (benefitId) {
                fetchBenefitInfo(benefitId);
            } else {
                hideBenefitInfo();
            }
        });

        document.getElementById('amountInput').addEventListener('input', validateAmount);
        document.getElementById('statusSelect').addEventListener('change', validateAmount);

        function fetchBenefitInfo(benefitId) {
            fetch(`/Disbursement/GetBenefitRemainingBalance?benefitId=${benefitId}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('benefitInfoCard').style.display = 'block';
                        document.getElementById('benefitType').textContent = data.benefitType;
                        document.getElementById('benefitAmount').textContent = '₹' + data.benefitAmount.toLocaleString('en-IN', {minimumFractionDigits: 2});
                        document.getElementById('totalDisbursed').textContent = '₹' + data.totalDisbursed.toLocaleString('en-IN', {minimumFractionDigits: 2});
                        document.getElementById('remainingBalance').textContent = '₹' + data.remainingBalance.toLocaleString('en-IN', {minimumFractionDigits: 2});

                        currentRemainingBalance = data.remainingBalance;

                        // Update color based on remaining balance
                        const remainingEl = document.getElementById('remainingBalance');
                        if (data.remainingBalance <= 0) {
                            remainingEl.className = 'fw-bold text-danger';
                        } else if (data.remainingBalance < data.benefitAmount * 0.2) {
                            remainingEl.className = 'fw-bold text-warning';
                        } else {
                            remainingEl.className = 'fw-bold text-success';
                        }

                        validateAmount();
                    } else {
                        showAmountError(data.message);
                    }
                })
                .catch(error => {
                    console.error('Error fetching benefit info:', error);
                    showAmountError('Error loading benefit information.');
                });
        }

        function hideBenefitInfo() {
            document.getElementById('benefitInfoCard').style.display = 'none';
            currentRemainingBalance = 0;
            hideAmountError();
        }

        function validateAmount() {
            const amount = parseFloat(document.getElementById('amountInput').value) || 0;
            const status = document.getElementById('statusSelect').value;
            const submitBtn = document.getElementById('submitBtn');

            if (amount <= 0) {
                showAmountError('Disbursement amount must be greater than zero.');
                submitBtn.disabled = true;
                return false;
            }

            // Only validate against remaining balance for "Completed" status
            if (status === 'Completed' && currentRemainingBalance > 0 && amount > currentRemainingBalance) {
                showAmountError(`Amount (₹${amount.toLocaleString('en-IN', {minimumFractionDigits: 2})}) exceeds remaining balance (₹${currentRemainingBalance.toLocaleString('en-IN', {minimumFractionDigits: 2})}). Please enter an amount ≤ ₹${currentRemainingBalance.toLocaleString('en-IN', {minimumFractionDigits: 2})}.`);
                submitBtn.disabled = true;
                return false;
            }

            if (currentRemainingBalance <= 0 && status === 'Completed' && document.getElementById('benefitSelect').value) {
                showAmountError('This benefit has been fully disbursed. No remaining balance available.');
                submitBtn.disabled = true;
                return false;
            }

            hideAmountError();
            submitBtn.disabled = false;
            return true;
        }

        function showAmountError(message) {
            document.getElementById('amountValidationAlert').style.display = 'block';
            document.getElementById('amountValidationMessage').textContent = message;
            document.getElementById('amountInput').classList.add('is-invalid');
        }

        function hideAmountError() {
            document.getElementById('amountValidationAlert').style.display = 'none';
            document.getElementById('amountInput').classList.remove('is-invalid');
        }

        // Form submission validation
        document.getElementById('disbursementForm').addEventListener('submit', function(e) {
            if (!validateAmount()) {
                e.preventDefault();
                return false;
            }
        });
    </script>
}
